{
  "database": {
    "id": "cosmicworks",
    "throughput": 400
  },
  "containers": [
    {
      "name": "posts",
      "partitionKey": "/id",
      "defaultTtl": -1,
      "indexingPolicy": {
        "indexingMode": "consistent",
        "automatic": true
      }
    },
    {
      "name": "authors",
      "partitionKey": "/id",
      "defaultTtl": -1,
      "indexingPolicy": {
        "indexingMode": "consistent",
        "automatic": true
      }
    }
  ]
}
